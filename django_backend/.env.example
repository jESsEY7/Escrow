# Django Escrow Platform - Environment Variables

# Django Settings
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/escrow_db

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Celery (Background Tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (for development, use console backend)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@escrow.com

# Payment Providers (Sandbox/Test Keys)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# M-Pesa (Sandbox)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_PASSKEY=
# MPESA_SHORTCODE=
# MPESA_CALLBACK_URL=http://localhost:8000/api/payments/mpesa/callback/

# Sentry (Error Monitoring - Optional)
# SENTRY_DSN=
